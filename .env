# ================================
# PostgreSQL Databases
# ================================
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Account Service DB
ACCOUNT_DB_HOST=bank-account-db
ACCOUNT_DB_PORT=5435
ACCOUNT_DB_NAME=accounts
ACCOUNT_DB_URL=jdbc:postgresql://${ACCOUNT_DB_HOST}:${POSTGRES_PORT}/${ACCOUNT_DB_NAME}

# Cash Service DB
CASH_DB_HOST=bank-cash-db
CASH_DB_PORT=5434
CASH_DB_NAME=cashes
CASH_DB_URL=jdbc:postgresql://${CASH_DB_HOST}:${POSTGRES_PORT}/${CASH_DB_NAME}

# Transfer Service DB
TRANSFER_DB_HOST=bank-transfer-db
TRANSFER_DB_PORT=5433
TRANSFER_DB_NAME=transfers
TRANSFER_DB_URL=jdbc:postgresql://${TRANSFER_DB_HOST}:${POSTGRES_PORT}/${TRANSFER_DB_NAME}

# Notification Service DB
NOTIFICATION_DB_HOST=bank-notification-db
NOTIFICATION_DB_PORT=5436
NOTIFICATION_DB_NAME=notifications
NOTIFICATION_DB_URL=jdbc:postgresql://${NOTIFICATION_DB_HOST}:${POSTGRES_PORT}/${NOTIFICATION_DB_NAME}

# ================================
# Service Ports
# ================================
FRONTEND_PORT=9000
GATEWAY_PORT=9001
KEYCLOAK_PORT=9002
TRANSFER_SERVICE_PORT=9003
CASH_SERVICE_PORT=9004
ACCOUNT_SERVICE_PORT=9005
NOTIFICATION_SERVICE_PORT=9006

# ================================
# Service URLs (for Discovery)
# ================================
GATEWAY_URL=http://gateway:${GATEWAY_PORT}
ACCOUNT_SERVICE_URL=http://account-service:${ACCOUNT_SERVICE_PORT}
CASH_SERVICE_URL=http://cash-service:${CASH_SERVICE_PORT}
TRANSFER_SERVICE_URL=http://transfer-service:${TRANSFER_SERVICE_PORT}
NOTIFICATION_SERVICE_URL=http://notification-service:${NOTIFICATION_SERVICE_PORT}

# ================================
# Spring Datasource (для каждого сервиса)
# ================================
# Account Service
SPRING_DATASOURCE_URL_ACCOUNT=${ACCOUNT_DB_URL}
SPRING_DATASOURCE_USERNAME_ACCOUNT=${POSTGRES_USER}
SPRING_DATASOURCE_PASSWORD_ACCOUNT=${POSTGRES_PASSWORD}

# Cash Service
SPRING_DATASOURCE_URL_CASH=${CASH_DB_URL}
SPRING_DATASOURCE_USERNAME_CASH=${POSTGRES_USER}
SPRING_DATASOURCE_PASSWORD_CASH=${POSTGRES_PASSWORD}

# Transfer Service
SPRING_DATASOURCE_URL_TRANSFER=${TRANSFER_DB_URL}
SPRING_DATASOURCE_USERNAME_TRANSFER=${POSTGRES_USER}
SPRING_DATASOURCE_PASSWORD_TRANSFER=${POSTGRES_PASSWORD}

# Notification Service
SPRING_DATASOURCE_URL_NOTIFICATION=${NOTIFICATION_DB_URL}
SPRING_DATASOURCE_USERNAME_NOTIFICATION=${POSTGRES_USER}
SPRING_DATASOURCE_PASSWORD_NOTIFICATION=${POSTGRES_PASSWORD}

# ================================
# Consul (Service Discovery)
# ================================
CONSUL_HOST=bank-consul #localhost
CONSUL_HTTP_PORT=8500
CONSUL_DNS_PORT=8600

# ================================
# Debezium
# ================================
DEBEZIUM_HOST=bank-debezium #localhost
DEBEZIUM_PORT=8083

# ================================
# Kafka
# ================================
KAFKA_HOST=bank-kafka #localhost
KAFKA_PORT=9092

# ================================
# Keycloak (Auth)
# ================================
KEYCLOAK_HOST=keycloak #localhost
KEYCLOAK_REALM=bank-realm
KEYCLOAK_ISSUER_URI=http://${KEYCLOAK_HOST}:${KEYCLOAK_PORT}/realms/${KEYCLOAK_REALM}
