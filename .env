# ================================
# PostgreSQL Databases
# ================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Account Service DB
ACCOUNT_DB_HOST=account-db
ACCOUNT_DB_PORT=5433
ACCOUNT_DB_NAME=accounts
ACCOUNT_DB_URL=jdbc:postgresql://${ACCOUNT_DB_HOST}:${ACCOUNT_DB_PORT}/${ACCOUNT_DB_NAME}

# Cash Service DB
CASH_DB_HOST=cash-db
CASH_DB_PORT=5434
CASH_DB_NAME=cash
CASH_DB_URL=jdbc:postgresql://${CASH_DB_HOST}:${CASH_DB_PORT}/${CASH_DB_NAME}

# Transfer Service DB
TRANSFER_DB_HOST=transfer-db
TRANSFER_DB_PORT=5435
TRANSFER_DB_NAME=transfers
TRANSFER_DB_URL=jdbc:postgresql://${TRANSFER_DB_HOST}:${TRANSFER_DB_PORT}/${TRANSFER_DB_NAME}

# ================================
# Service Ports
# ================================
FRONTEND_PORT=9000
GATEWAY_PORT=9001
KEYCLOAK_PORT=9002
TRANSFER_SERVICE_PORT=9003
CASH_SERVICE_PORT=9004
ACCOUNT_SERVICE_PORT=9005

# ================================
# Service URLs (for Discovery)
# ================================
ACCOUNT_SERVICE_URL=http://account-service:${ACCOUNT_SERVICE_PORT}
CASH_SERVICE_URL=http://cash-service:${CASH_SERVICE_PORT}
TRANSFER_SERVICE_URL=http://transfer-service:${TRANSFER_SERVICE_PORT}
GATEWAY_URL=http://gateway:${GATEWAY_PORT}

# ================================
# Spring Datasource (для каждого сервиса)
# ================================
# Account Service
SPRING_DATASOURCE_URL_ACCOUNT=${ACCOUNT_DB_URL}
SPRING_DATASOURCE_USERNAME_ACCOUNT=${POSTGRES_USER}
SPRING_DATASOURCE_PASSWORD_ACCOUNT=${POSTGRES_PASSWORD}

# Cash Service
SPRING_DATASOURCE_URL_CASH=${CASH_DB_URL}
SPRING_DATASOURCE_USERNAME_CASH=${POSTGRES_USER}
SPRING_DATASOURCE_PASSWORD_CASH=${POSTGRES_PASSWORD}

# Transfer Service
SPRING_DATASOURCE_URL_TRANSFER=${TRANSFER_DB_URL}
SPRING_DATASOURCE_USERNAME_TRANSFER=${POSTGRES_USER}
SPRING_DATASOURCE_PASSWORD_TRANSFER=${POSTGRES_PASSWORD}

# ================================
# Consul (Service Discovery)
# ================================
CONSUL_HOST=consul-server #localhost
CONSUL_HTTP_PORT=8500
CONSUL_DNS_PORT=8600

# ================================
# Keycloak (Auth)
# ================================
KEYCLOAK_HOST=keycloak #localhost
KEYCLOAK_REALM=bank-realm
KEYCLOAK_ISSUER_URI=http://${KEYCLOAK_HOST}:${KEYCLOAK_PORT}/realms/${KEYCLOAK_REALM}


#USER_CLIENT_BASE_URL=http://host.docker.internal:8081